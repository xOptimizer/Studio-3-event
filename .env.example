# Supabase: use session pooler on port 5432 (NOT transaction pooler on 6543).
# Checkout uses Prisma interactive transactions, which require a session-scoped connection.
# If Prisma still can't connect locally, scripts set NODE_OPTIONS=--dns-result-order=ipv4first
DATABASE_URL=postgresql://postgres.veimhqjzppbdmyrlvrut:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
# Login link in ticket emails (guests + paid participants)
PUBLIC_SITE_URL=https://studiosthree.com

# Finix (map FINIX_USERNAME / FINIX_PASSWORD from Finix Dashboard if needed)
FINIX_ENV=sandbox
FINIX_API_USERNAME=
FINIX_API_PASSWORD=
FINIX_MERCHANT_IDENTITY_ID=
# Shown on Apple Pay sheet and Google Pay merchant info
FINIX_MERCHANT_DISPLAY_NAME=Studio 3
# Optional in backend .env (reference only — used by frontend Finix.js Auth)
# FINIX_APPLICATION_ID=
# FINIX_MERCHANT_ID=
FINIX_WEBHOOK_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=tickets@studio3.dallas

EVENT_SLUG=inside-the-mind-2026
# Optional: public URL for event poster on ticket PDFs (if no local file in assets/posters/)
# EVENT_POSTER_URL=https://example.com/poster.jpg
# Optional: email header banner (defaults to PUBLIC_SITE_URL/assets/Ticket%20Banner.jpg)
# EVENT_EMAIL_BANNER_URL=https://studiosthree.com/assets/Ticket%20Banner.jpg
PORT=3001

# Seed script only
ADMIN_EMAIL=admin@studio3.dallas
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Studio 3 Admin
